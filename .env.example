# PrajaVaani Eligibility Checker - Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Server Configuration ====================
NODE_ENV=development
PORT=5000
HOSTNAME=localhost

# ==================== Frontend Configuration ====================
REACT_APP_API_URL=http://localhost:5000
REACT_APP_API_TIMEOUT=30000

# ==================== Database (Optional - for future caching) ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=prajavaani
DB_PASSWORD=secret
DB_NAME=eligibility

# ==================== Redis (Optional - for caching) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Logging ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ==================== Security ====================
CORS_ORIGIN=*
SECRET_KEY=your_secret_key_here

# ==================== Deployment ====================
# Set for production deployments
# API_GATEWAY_URL=https://api.prajavaani.app
# FRONTEND_URL=https://prajavaani.app
